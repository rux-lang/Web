import Io::Print;

// Regular function
func Max(a: int32, b: int32) -> int32 {
    return a > b ? a : b;
}

// Generic function
func Div<T>(x: T, y: T) -> T {
    return x / y;
}

func Main() -> int {
    let quotient = Div<float>(10.0, 2.0);
    let max = Max(5, 10);
    Print("Max: {}, Quotient: {}", max, quotient);
    return 0;
}
